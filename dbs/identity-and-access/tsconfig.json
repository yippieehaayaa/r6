{
	"extends": "@r6/typescript-config/base.json",
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"target": "ESNext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "tsup.config.ts"],
	"exclude": ["node_modules", "generated", "dist", "prisma"]
}
