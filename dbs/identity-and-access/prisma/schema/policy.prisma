// ============================================================
//  POLICY  (Permission Set)
//  Defines a named set of permissions that can be attached to Roles.
//  Permissions are always implicitly ALLOW — the system is deny-by-default,
//  so any permission not granted is already denied.
//
//  Fields:
//    permissions — list of action strings the policy covers.
//                  Convention: "service:resource:action"
//                  e.g. "inventory:stock:read"
//                       "inventory:stock:write"
//                       "procurement:purchase-order:approve"
//    displayName — optional human-readable label shown in UI.
//                  e.g. "Stock Management", "POS Cashier"
//    isManaged   — true for platform-seeded policies that tenants
//                  cannot edit or delete.
//
//  Policies are tenant-scoped. tenantId = null is reserved
//  for platform-level policies attached to ADMIN roles.
//
//  Example policies:
//    name: "inventory-stock-read"
//      displayName: "View Stock"
//      permissions: ["inventory:stock:read"]
//
//    name: "pos-cashier"
//      displayName: "POS Cashier"
//      permissions: ["inventory:stock:read", "pos:sale:create"]
// ============================================================

model Policy {
    id          String  @id @default(uuid()) @db.Uuid
    // All policies belong to a tenant.
    // Platform-level policies (for ADMIN roles) belong to the platform tenant.
    tenantId    String  @db.Uuid
    name        String
    displayName String? // human-readable label shown in the UI
    description String?
    permissions String[] // e.g. ["inventory:stock:read", "inventory:stock:write"]
    isManaged   Boolean @default(false) // true = platform-seeded, tenants cannot edit/delete

    // Relations
    tenant             Tenant             @relation("TenantPolicies", fields: [tenantId], references: [id], onDelete: Cascade)
    invitationPolicies InvitationPolicy[] // policies available to attach to invitations

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    @@unique([tenantId, name])
    @@index([tenantId])
    @@index([deletedAt])
    @@map("policies")
}
