// ============================================================
//  IDENTITY
//  Represents a human user, service account, or platform admin.
//
//  Multi-tenancy:
//    tenantId is null for ADMIN identities (platform-level).
//    All USER and SERVICE identities must have a tenantId.
//    This is the same tenantId stamped on every record across
//    all other microservices (Inventory, Procurement, etc.).
//
//  Removed from original:
//    • Session       — handled externally (JWT / refresh tokens
//                      managed at the API Gateway layer)
//    • PasswordHistory, EmailHistory, IpAddress — audit detail
//                      not needed for a demo; can be added later
//
//  Cross-service usage:
//    Identity.id (identityId) is the value stored as
//    performedBy on StockMovement, AuditLog, StockCount, etc.
//    across all services. No cross-DB FK — services store the
//    UUID string and call IAM to resolve display names if needed.
// ============================================================

model Identity {
    id                  String         @id @default(uuid()) @db.Uuid
    // tenantId: null = platform ADMIN, required for USER and SERVICE
    tenantId            String?        @db.Uuid
    username            String
    email               String?
    hash                String // bcrypt hash of password
    salt                String // per-identity salt
    failedLoginAttempts Int            @default(0)
    lockedUntil         DateTime? // set when SUSPENDED due to failed logins
    mustChangePassword  Boolean        @default(true) // force reset on first login
    kind                IdentityKind   @default(USER)
    status              IdentityStatus @default(PENDING_VERIFICATION)

    // TOTP (optional authenticator-app based 2FA)
    totpSecret         String? // AES-256-GCM encrypted TOTP secret; null when TOTP not set up
    totpEnabled        Boolean        @default(false)
    totpVerifiedAt     DateTime? // when the secret was first confirmed by the identity

    // Relations
    roles          Role[]         // many-to-many via implicit join table
    refreshTokens  RefreshToken[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    // username unique per tenant (two tenants can have the same username)
    @@unique([tenantId, username])
    // email unique per tenant
    @@unique([tenantId, email])
    @@index([tenantId])
    @@index([tenantId, status])
    @@index([tenantId, kind])
    @@index([deletedAt])
    @@map("identities")
}
