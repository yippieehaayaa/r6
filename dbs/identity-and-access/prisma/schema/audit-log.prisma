model AuditLog {
    id        String       @id @default(uuid())
    actorId   String?
    actorKind String?
    action    String
    resource  String
    outcome   AuditOutcome
    metadata  Json?
    ipAddress String?
    userAgent String?

    // Timestamps
    createdAt DateTime @default(now())

    // Indexes
    @@index([actorId])
    @@index([action])
    @@index([createdAt])
    @@map("audit_logs")
}
