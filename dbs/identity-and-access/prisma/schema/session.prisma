model Session {
    id        String    @id @default(uuid())
    token     String    @unique
    kind      TokenKind @default(REFRESH)
    audience  String[]
    family    String
    ipAddress String?
    userAgent String?

    // Timestamps
    createdAt DateTime  @default(now())
    expiresAt DateTime
    revokedAt DateTime?

    // References
    identityId String
    identity   Identity @relation(fields: [identityId], references: [id])

    // Indexes
    @@index([identityId])
    @@index([family])
    @@index([expiresAt])
    @@map("sessions")
}