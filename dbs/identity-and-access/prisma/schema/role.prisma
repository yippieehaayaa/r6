// ============================================================
//  ROLE
//  A named collection of policies assigned to identities.
//  Roles are tenant-scoped — each tenant manages their own
//  roles independently. Platform-wide roles (tenantId = null)
//  are reserved for ADMIN identities only.
//
//  Examples:
//    "Warehouse Manager"  — can adjust stock, run cycle counts
//    "Procurement Officer" — can raise and approve POs
//    "Cashier"            — POS terminal access only
//    "Finance Viewer"     — read-only financial reports
// ============================================================

model Role {
    id          String  @id @default(uuid()) @db.Uuid
    // All roles belong to a tenant.
    // Platform-level roles (for ADMIN identities) belong to the platform tenant.
    tenantId    String  @db.Uuid
    name        String
    description String?
    isActive    Boolean @default(true)

    // Relations
    tenant        Tenant       @relation("TenantRoles", fields: [tenantId], references: [id], onDelete: Cascade)
    rolePolicies  RolePolicy[] // explicit join table (replaces implicit Policy[])
    identityRoles IdentityRole[] // explicit join table (replaces implicit Identity[])
    invitations   Invitation[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // role names unique per tenant
    @@unique([tenantId, name])
    @@index([tenantId])
    @@index([tenantId, isActive])
    @@index([deletedAt])
    @@map("roles")
}
