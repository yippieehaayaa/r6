// ============================================================
//  ROLE
//  A named collection of policies assigned to identities.
//  Roles are tenant-scoped — each tenant manages their own
//  roles independently. Platform-wide roles (tenantId = null)
//  are reserved for ADMIN identities only.
//
//  Examples:
//    "Warehouse Manager"  — can adjust stock, run cycle counts
//    "Procurement Officer" — can raise and approve POs
//    "Cashier"            — POS terminal access only
//    "Finance Viewer"     — read-only financial reports
// ============================================================

model Role {
    id          String  @id @default(uuid()) @db.Uuid
    tenantId    String? @db.Uuid // null = platform-level role (ADMIN only)
    name        String
    description String?
    isActive    Boolean @default(true)

    // Relations
    policies   Policy[] // many-to-many via implicit join table
    identities Identity[] // many-to-many via implicit join table

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // role names unique per tenant
    @@unique([tenantId, name])
    @@index([tenantId])
    @@index([tenantId, isActive])
    @@index([deletedAt])
    @@map("roles")
}
