// ============================================================
//  TENANT
//  Represents a company (client) using the ERP SaaS platform.
//  This is the record that owns the tenantId used across ALL
//  microservices (Inventory, Procurement, Transaction, etc.).
//
//  The Tenant model lives here in IAM because tenant lifecycle
//  (onboarding, suspension, offboarding) is an identity concern.
//
//  moduleAccess:
//    JSON list of enabled microservices for this tenant.
//    Enforced at the API Gateway via policy audience checks.
//    e.g. ["inventory", "procurement", "pos", "financial"]
//    Starter tier:    ["inventory", "pos"]
//    Growth tier:     ["inventory", "procurement", "pos", "financial"]
//    Enterprise tier: ["inventory", "procurement", "pos",
//                      "financial", "request", "rma"]
//
// ============================================================

model Tenant {
    id           String         @id @default(uuid()) @db.Uuid
    name         String         @unique // company name
    slug         String         @unique // url-safe identifier e.g. "acme-corp"
    isActive     Boolean        @default(true)
    isPlatform   Boolean        @default(false) // true for the single platform tenant that owns ADMIN identities
    moduleAccess TenantModule[] // enabled microservice names (enum-typed)

    // Primary owner identity for this tenant.
    // Nullable because the owner identity is created after the tenant row
    // inside createTenantWithDefaults, then back-patched via tenant.update.
    ownerId String?   @db.Uuid
    owner   Identity? @relation("TenantOwner", fields: [ownerId], references: [id], onDelete: SetNull)

    // Back-relations
    identities          Identity[]           @relation("TenantIdentities")
    policies            Policy[]             @relation("TenantPolicies")
    identityPermissions IdentityPermission[] @relation("TenantIdentityPermissions") // per-user permission overrides
    invitations         Invitation[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    @@index([isActive])
    @@index([isPlatform])
    @@index([ownerId])
    @@index([deletedAt])
    @@map("tenants")
}
