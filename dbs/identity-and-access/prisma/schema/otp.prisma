model Otp {
    id       String     @id @default(uuid())
    code     String
    purpose  OtpPurpose
    status   OtpStatus  @default(PENDING)
    attempts Int        @default(0)

    // Timestamps
    sentAt     DateTime  @default(now())
    expiresAt  DateTime
    verifiedAt DateTime?

    // References
    identityId String
    identity   Identity @relation(fields: [identityId], references: [id])

    // Indexes
    @@index([identityId, purpose, status])
    @@index([expiresAt])
    @@map("otps")
}