// ============================================================
//  INVENTORY
//  Single source of truth for all stock data.
//
//  Owns:
//    • Where stock is and how much      (Warehouse, InventoryItem)
//    • Which batch it came from         (InventoryLot)
//    • Individual unit tracking         (SerializedUnit)
//    • Why stock changed                (StockMovement — immutable ledger)
//    • Warehouse locations              (WarehouseZone, BinLocation)
//    • Warehouse-to-warehouse transfers (StockTransfer, StockTransferItem)
//    • Physical stock counts            (StockCount, StockCountItem)
//    • Stock alerts                     (StockAlert)
//    • Return merchandise               (ReturnRequest, ReturnRequestItem)
//    • Master data change log           (AuditLog)
//
//  Does NOT own:
//    • Pricing              → Pricing Service
//    • Supplier data        → Procurement Service
//    • Purchase orders      → Procurement Service
//    • Sale records         → Transaction Service
//    • Financial ledger     → Financial Service
//    • Stock request        → Request System
//
//  Cross-service contract:
//    All stock mutations go through this service's API.
//    Every write atomically updates InventoryItem AND appends
//    a StockMovement in a single DB transaction.
//    referenceId + referenceType on StockMovement and
//    InventoryLot are the audit trail back to the originating
//    document in an external service — no hard cross-DB FKs.
//
//  Costing (via InventoryLot):
//    FIFO  — oldest lot with remaining stock is depleted first.
//            Enforced at application layer using receivedAt index.
//    AVCO  — weighted average across all active lots.
//            Computed at application layer; not stored.
//    Costing method is a per-tenant configuration in IAM Service.
//
//  Multi-tenancy:
//    tenantId on every model. PostgreSQL RLS enforces isolation
//    at the DB layer — no application-layer tenant filtering needed.
// ============================================================

// ─── Warehouse ───────────────────────────────────────────────

// Physical or logical location that holds stock.
model Warehouse {
    id       String @id @default(uuid()) @db.Uuid
    tenantId String @db.Uuid
    name     String
    code     String // short code e.g. "WH-MNL", "WH-CDO"

    // Status
    isActive Boolean @default(true)

    // Flattened address (no join for single-owner entity)
    addressLine1    String
    addressLine2    String?
    addressBarangay String?
    addressCity     String
    addressState    String
    addressCountry  String
    addressPostal   String

    // Relations
    zones          WarehouseZone[]
    inventoryItems InventoryItem[]
    inventoryLots  InventoryLot[]
    stockMovements StockMovement[]
    transfersFrom  StockTransfer[] @relation("TransferFrom")
    transfersTo    StockTransfer[] @relation("TransferTo")
    stockCounts    StockCount[]
    alerts         StockAlert[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@unique([tenantId, code])
    @@unique([tenantId, name])
    @@index([tenantId])
    @@index([tenantId, isActive])
    @@index([deletedAt])
    @@map("warehouses")
}

// Named zone within a warehouse (e.g. "Zone A — Refrigerated", "Zone B — Dry Goods").
// Enables directed putaway and picking workflows.
model WarehouseZone {
    id          String  @id @default(uuid()) @db.Uuid
    tenantId    String  @db.Uuid
    warehouseId String  @db.Uuid
    name        String
    code        String
    description String?

    // Status
    isActive Boolean @default(true)

    // Relations
    warehouse    Warehouse     @relation(fields: [warehouseId], references: [id])
    binLocations BinLocation[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@unique([tenantId, warehouseId, code])
    @@index([tenantId])
    @@index([tenantId, warehouseId])
    @@map("warehouse_zones")
}

// Specific shelf/bin location within a zone (e.g. "A-01-03" = Zone A, Aisle 01, Shelf 03).
// InventoryLot optionally carries a binLocationId for directed picking.
model BinLocation {
    id          String  @id @default(uuid()) @db.Uuid
    tenantId    String  @db.Uuid
    zoneId      String  @db.Uuid
    code        String // e.g. "A-01-03"
    description String?

    // Status
    isActive Boolean @default(true)

    // Relations
    zone            WarehouseZone    @relation(fields: [zoneId], references: [id])
    inventoryLots   InventoryLot[]
    stockCountItems StockCountItem[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@unique([tenantId, zoneId, code])
    @@index([tenantId])
    @@index([tenantId, zoneId])
    @@map("bin_locations")
}

// ─── Stock Levels ─────────────────────────────────────────────

// Aggregate stock level for a variant at a warehouse.
// Always updated atomically alongside every StockMovement write.
//
//   quantityAvailable = quantityOnHand - quantityReserved
//
// This is the fast-read summary for availability checks.
// For per-batch costing detail, see InventoryLot.
// For individual unit tracking, see SerializedUnit.
model InventoryItem {
    id                 String @id @default(uuid()) @db.Uuid
    tenantId           String @db.Uuid
    quantityOnHand     Int    @default(0) // physical units confirmed in warehouse
    quantityReserved   Int    @default(0) // soft-held by POS carts or Request System
    reorderPoint       Int    @default(0) // LOW_STOCK alert fires when available ≤ this
    reorderQuantity    Int    @default(0) // suggested order quantity when reorder triggered
    overstockThreshold Int    @default(0) // OVERSTOCK alert fires when onHand ≥ this (0 = disabled)

    // Relations
    variantId   String         @db.Uuid
    variant     ProductVariant @relation(fields: [variantId], references: [id])
    warehouseId String         @db.Uuid
    warehouse   Warehouse      @relation(fields: [warehouseId], references: [id])

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@unique([tenantId, variantId, warehouseId])
    @@index([tenantId])
    @@index([tenantId, warehouseId])
    @@index([tenantId, variantId])
    @@map("inventory_items")
}

// ─── Inventory Lot ───────────────────────────────────────────

// A single received batch of a variant — the costing layer.
// One lot is created per GRN line item (per variant per delivery).
// unitCost is frozen at receipt time and never changes.
//
// FIFO depletion:
//   Service queries: WHERE variantId = X AND warehouseId = Y
//     AND quantityRemaining > 0 AND isQuarantined = false
//     ORDER BY receivedAt ASC
//   Deducts from the oldest lot first. Returns unitCost to
//   Transaction Service for snapshot onto SaleLineItem.unitCost.
//
// AVCO depletion:
//   Service computes: SUM(quantityRemaining × unitCost) /
//     SUM(quantityRemaining) across all active lots.
//   Returns the weighted average as the snapshot unitCost.
//
// FEFO (First Expired First Out):
//   For perishables: ORDER BY expiresAt ASC instead of receivedAt.
//   Applied when ProductVariant has trackingType = BATCH and
//   expiresAt is set on the lot.
//
// referenceId   — GRN.id in the Procurement Service
// referenceType — "GOODS_RECEIPT_NOTE" | "STOCK_ADJUSTMENT" | "RETURN"
model InventoryLot {
    id                String    @id @default(uuid()) @db.Uuid
    tenantId          String    @db.Uuid
    quantityReceived  Int // total units in this lot on arrival
    quantityRemaining Int // units still available — decremented on SALE/DAMAGE
    unitCost          Decimal   @db.Decimal(12, 2) // frozen cost per base UOM unit at time of receipt
    unitCostCurrency  String    @default("PHP") // ISO 4217 — supports multi-currency tenants
    receivedAt        DateTime // physical arrival date — FIFO ordering key
    expiresAt         DateTime? // for FEFO — null means non-perishable
    isQuarantined     Boolean   @default(false) // true = excluded from available stock immediately
    referenceId       String? // GRN.id in Procurement Service
    referenceType     String? // e.g. "GOODS_RECEIPT_NOTE"
    notes             String?

    // Relations
    variantId          String              @db.Uuid
    variant            ProductVariant      @relation(fields: [variantId], references: [id])
    warehouseId        String              @db.Uuid
    warehouse          Warehouse           @relation(fields: [warehouseId], references: [id])
    binLocationId      String?             @db.Uuid
    binLocation        BinLocation?        @relation(fields: [binLocationId], references: [id])
    serializedUnits    SerializedUnit[]
    stockMovements     StockMovement[]
    transferItems      StockTransferItem[]
    stockCountItems    StockCountItem[]
    returnRequestItems ReturnRequestItem[]
    stockAlerts        StockAlert[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    // Primary FIFO query
    @@index([tenantId, variantId, warehouseId, receivedAt])
    // Available stock query (excludes empty + quarantined lots)
    @@index([tenantId, variantId, warehouseId, quantityRemaining])
    // FEFO query
    @@index([tenantId, variantId, warehouseId, expiresAt])
    // Expiry alert job
    @@index([tenantId, expiresAt])
    // Cross-service traceability
    @@index([referenceId])
    @@map("inventory_lots")
}

// ─── Serialized Unit ─────────────────────────────────────────

// Individual unit tracking for high-value or regulated items
// (electronics, medical devices, etc.).
// Only used when ProductVariant.trackingType = SERIAL.
// Sits inside an InventoryLot — the lot provides the costing;
// the serialized unit provides the identity.
//
// saleReferenceId — SaleTransaction.id in Transaction Service
//   Set when the unit is sold. Enables warranty tracking,
//   loss investigation, and regulatory compliance.
model SerializedUnit {
    id              String               @id @default(uuid()) @db.Uuid
    tenantId        String               @db.Uuid
    serialNumber    String // manufacturer or internal serial number
    status          SerializedUnitStatus
    saleReferenceId String? // SaleTransaction.id — set on SOLD
    notes           String?

    // Relations
    variantId String         @db.Uuid
    variant   ProductVariant @relation(fields: [variantId], references: [id])
    lotId     String         @db.Uuid
    lot       InventoryLot   @relation(fields: [lotId], references: [id])

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@unique([tenantId, serialNumber])
    @@index([tenantId])
    @@index([tenantId, variantId, status])
    @@index([tenantId, lotId])
    @@index([saleReferenceId])
    @@map("serialized_units")
}

// ─── Stock Movement Ledger ───────────────────────────────────

// Immutable audit log — append-only, NEVER updated or deleted.
// Every unit entering or leaving inventory must have a row here.
//
// Quantity convention:
//   positive (+) = stock in  (RECEIPT, RETURN, TRANSFER_IN, ADJUSTMENT when adding)
//   negative (-) = stock out (SALE, DAMAGE, TRANSFER_OUT, ADJUSTMENT when removing)
//
// lotId:
//   Set on outbound movements (SALE, DAMAGE, TRANSFER_OUT, RETURN).
//   Null on RECEIPT — the lot is being created, not consumed.
//   This is the link Financial Service uses to resolve unitCost
//   for every unit sold.
//
// Cross-service traceability:
//   referenceId   — ID of the originating document in the external service
//                   e.g. GRN.id, SaleTransaction.id, StockRequest.id, StockTransfer.id
//   referenceType — document type in the external service
//                   "GOODS_RECEIPT_NOTE" | "SALE_TRANSACTION" | "STOCK_REQUEST" |
//                   "STOCK_TRANSFER" | "RETURN_REQUEST" | "STOCK_COUNT"
//   performedBy   — IAM identity ID of the actor. No cross-DB FK by design.
model StockMovement {
    id            String       @id @default(uuid()) @db.Uuid
    tenantId      String       @db.Uuid
    type          MovementType
    quantity      Int // positive = in, negative = out (in base UOM)
    referenceId   String? // originating document ID in external service
    referenceType String? // originating document type
    notes         String?
    performedBy   String // IAM identity ID

    // Relations
    variantId   String         @db.Uuid
    variant     ProductVariant @relation(fields: [variantId], references: [id])
    warehouseId String         @db.Uuid
    warehouse   Warehouse      @relation(fields: [warehouseId], references: [id])
    // Which lot was consumed (null on RECEIPT — lot is being created)
    lotId       String?        @db.Uuid
    lot         InventoryLot?  @relation(fields: [lotId], references: [id])

    // Append-only: createdAt only — no updatedAt
    createdAt DateTime @default(now())

    // Indexes
    @@index([tenantId, variantId])
    @@index([tenantId, variantId, createdAt])
    @@index([tenantId, warehouseId])
    @@index([tenantId, warehouseId, type, createdAt])
    @@index([tenantId, lotId])
    @@index([tenantId, type])
    @@index([tenantId, type, createdAt])
    @@index([tenantId, referenceId])
    @@index([tenantId, referenceType])
    @@index([tenantId, createdAt])
    @@map("stock_movements")
}

// ─── Stock Transfer ───────────────────────────────────────────

// Document tracking warehouse-to-warehouse stock movement.
// Prevents the "ghost stock" problem: stock that has left the
// source but not yet arrived at the destination is tracked here.
//
// Workflow:
//   DRAFT → IN_TRANSIT:
//     StockMovement(TRANSFER_OUT) on source warehouse.
//     InventoryItem.quantityOnHand decremented at source.
//   IN_TRANSIT → COMPLETED (or PARTIALLY_RECEIVED):
//     StockMovement(TRANSFER_IN) on destination warehouse.
//     New InventoryLot created at destination with same unitCost
//     as the source lot — cost basis is preserved across transfers.
model StockTransfer {
    id          String         @id @default(uuid()) @db.Uuid
    tenantId    String         @db.Uuid
    status      TransferStatus @default(DRAFT)
    expectedAt  DateTime?
    notes       String?
    performedBy String // IAM identity ID

    // Relations
    fromWarehouseId String              @db.Uuid
    fromWarehouse   Warehouse           @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
    toWarehouseId   String              @db.Uuid
    toWarehouse     Warehouse           @relation("TransferTo", fields: [toWarehouseId], references: [id])
    items           StockTransferItem[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@index([tenantId])
    @@index([tenantId, status])
    @@index([tenantId, fromWarehouseId])
    @@index([tenantId, toWarehouseId])
    @@map("stock_transfers")
}

// Individual line item on a stock transfer.
model StockTransferItem {
    id                String @id @default(uuid()) @db.Uuid
    tenantId          String @db.Uuid
    quantityRequested Int
    quantityShipped   Int    @default(0)
    quantityReceived  Int    @default(0)

    // Relations
    transferId String         @db.Uuid
    transfer   StockTransfer  @relation(fields: [transferId], references: [id])
    variantId  String         @db.Uuid
    variant    ProductVariant @relation(fields: [variantId], references: [id])
    // Source lot — cost basis travels with the transfer
    lotId      String         @db.Uuid
    lot        InventoryLot   @relation(fields: [lotId], references: [id])

    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Indexes
    @@unique([tenantId, transferId, variantId, lotId])
    @@index([tenantId])
    @@index([tenantId, transferId])
    @@index([tenantId, variantId])
    @@map("stock_transfer_items")
}

// ─── Stock Count ──────────────────────────────────────────────

// Physical stock count (cycle count / full stock take).
// On completion: ADJUSTMENT movements are auto-generated for
// every StockCountItem where variance ≠ 0.
// StockAlert(COUNT_VARIANCE) fires if abs(variance) > threshold.
model StockCount {
    id          String           @id @default(uuid()) @db.Uuid
    tenantId    String           @db.Uuid
    status      StockCountStatus @default(DRAFT)
    countedAt   DateTime?
    completedAt DateTime?
    notes       String?
    performedBy String // IAM identity ID

    // Relations
    warehouseId String           @db.Uuid
    warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])
    items       StockCountItem[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@index([tenantId])
    @@index([tenantId, warehouseId])
    @@index([tenantId, status])
    @@map("stock_counts")
}

// One counted line per variant per bin location.
// quantityExpected — what the system believed was there.
// quantityActual   — what staff physically counted.
// variance         = quantityActual - quantityExpected
model StockCountItem {
    id               String  @id @default(uuid()) @db.Uuid
    tenantId         String  @db.Uuid
    quantityExpected Int
    quantityActual   Int     @default(0)
    variance         Int     @default(0) // computed: quantityActual - quantityExpected
    varianceReason   String?
    isReconciled     Boolean @default(false)

    // Relations
    stockCountId  String         @db.Uuid
    stockCount    StockCount     @relation(fields: [stockCountId], references: [id])
    variantId     String         @db.Uuid
    variant       ProductVariant @relation(fields: [variantId], references: [id])
    lotId         String?        @db.Uuid
    lot           InventoryLot?  @relation(fields: [lotId], references: [id])
    binLocationId String?        @db.Uuid
    binLocation   BinLocation?   @relation(fields: [binLocationId], references: [id])

    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Indexes
    @@unique([tenantId, stockCountId, variantId, lotId])
    @@index([tenantId])
    @@index([tenantId, stockCountId])
    @@map("stock_count_items")
}

// ─── Stock Alert ─────────────────────────────────────────────

// Fired by the Inventory Service when a threshold condition is met.
// Consumed by:
//   LOW_STOCK / OUT_OF_STOCK → Procurement Service (auto-draft PO)
//   LOT_EXPIRING / LOT_EXPIRED → Notification Service
//   COUNT_VARIANCE → Notification Service + Financial Service
//   OVERSTOCK → Procurement Service (suppress reorder)
model StockAlert {
    id         String      @id @default(uuid()) @db.Uuid
    tenantId   String      @db.Uuid
    alertType  AlertType
    status     AlertStatus @default(OPEN)
    threshold  Int? // the configured threshold that was breached
    currentQty Int? // quantity at time of alert
    resolvedAt DateTime?
    resolvedBy String? // IAM identity ID
    notes      String?

    // Relations
    variantId   String         @db.Uuid
    variant     ProductVariant @relation(fields: [variantId], references: [id])
    warehouseId String         @db.Uuid
    warehouse   Warehouse      @relation(fields: [warehouseId], references: [id])
    lotId       String?        @db.Uuid
    lot         InventoryLot?  @relation(fields: [lotId], references: [id])

    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Indexes
    @@index([tenantId])
    @@index([tenantId, status])
    @@index([tenantId, alertType, status])
    @@index([tenantId, variantId, alertType])
    @@index([tenantId, warehouseId])
    @@map("stock_alerts")
}

// ─── Return Request ──────────────────────────────────────────

// Structured RMA (Return Merchandise Authorization) process.
// Initiated by Transaction Service (customer return) or
// Procurement Service (supplier return).
//
// On completion per item:
//   RESTOCK            → StockMovement(RETURN), lot quantityRemaining++
//                        or new InventoryLot created if lot no longer exists
//   DAMAGE             → StockMovement(DAMAGE), write-off
//   RETURN_TO_SUPPLIER → passed to Procurement as a supplier return order
model ReturnRequest {
    id            String              @id @default(uuid()) @db.Uuid
    tenantId      String              @db.Uuid
    referenceId   String // SaleTransaction.id or GRN.id
    referenceType String // "SALE_TRANSACTION" | "GOODS_RECEIPT_NOTE"
    status        ReturnRequestStatus
    returnReason  String?
    performedBy   String // IAM identity ID

    // Relations
    items ReturnRequestItem[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@index([tenantId])
    @@index([tenantId, status])
    @@index([tenantId, referenceId])
    @@map("return_requests")
}

// One return line per variant per return request.
model ReturnRequestItem {
    id               String            @id @default(uuid()) @db.Uuid
    tenantId         String            @db.Uuid
    quantityReturned Int
    disposition      ReturnDisposition
    dispositionNotes String?

    // Relations
    returnRequestId String         @db.Uuid
    returnRequest   ReturnRequest  @relation(fields: [returnRequestId], references: [id])
    variantId       String         @db.Uuid
    variant         ProductVariant @relation(fields: [variantId], references: [id])
    // Original lot the unit came from (for correct FIFO reversal)
    lotId           String?        @db.Uuid
    lot             InventoryLot?  @relation(fields: [lotId], references: [id])

    // Serial number for SERIAL-tracked variants
    serialNumber String?

    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Indexes
    @@index([tenantId])
    @@index([tenantId, returnRequestId])
    @@index([tenantId, variantId])
    @@map("return_request_items")
}

// ─── Audit Log ───────────────────────────────────────────────

// Immutable log of all master data changes on critical models.
// StockMovement handles quantity changes. AuditLog handles
// everything else: price updates, status changes, reorderPoint
// edits, warehouse deactivations, etc.
//
// Required for regulatory compliance and financial audit trails.
// before / after are JSON snapshots of the changed record.
model AuditLog {
    id         String      @id @default(uuid()) @db.Uuid
    tenantId   String      @db.Uuid
    entityType String // e.g. "ProductVariant" | "InventoryItem" | "Warehouse"
    entityId   String // UUID of the changed record
    action     AuditAction
    changedBy  String // IAM identity ID
    before     Json? // full record snapshot before change
    after      Json? // full record snapshot after change

    // Append-only — createdAt only, no updatedAt
    createdAt DateTime @default(now())

    // Indexes
    @@index([tenantId])
    @@index([tenantId, entityType, entityId])
    @@index([tenantId, entityId])
    @@index([tenantId, changedBy])
    @@index([tenantId, createdAt])
    @@map("audit_logs")
}
