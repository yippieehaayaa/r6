// ============================================================
//  CATALOG
//  Owns the product taxonomy and master product data.
//  No pricing lives here — pricing is the Pricing Service's
//  concern. No supplier data — that belongs to Procurement.
//
//  The atomic unit shared across ALL microservices is:
//    ProductVariant.id (variantId) + ProductVariant.sku
//  Every other service (Procurement, Transaction, Financial,
//  Pricing, Request System) references variantId in its own
//  database. No hard cross-database foreign keys.
//
//  Multi-tenancy:
//    tenantId is present on every model. Row-level security
//    (RLS) is enforced at the PostgreSQL layer — every query
//    is automatically filtered to the current tenant via a
//    session variable set at connection time.
// ============================================================

// ─── Unit of Measure ─────────────────────────────────────────

// A named unit of measure (e.g. Piece, Case, Kilogram, Bottle).
// Stock is always tracked in the BASE UOM. Purchase and sale
// UOMs are converted via UomConversion at the service layer.
model UnitOfMeasure {
    id           String  @id @default(uuid()) @db.Uuid
    tenantId     String  @db.Uuid
    name         String // e.g. "Piece", "Case", "Kilogram"
    abbreviation String // e.g. "pcs", "cs", "kg"
    uomType      UomType @default(BASE)

    // Status
    isActive Boolean @default(true)

    // Relations
    productVariants ProductVariant[]
    conversionFrom  UomConversion[]  @relation("ConversionFrom")
    conversionTo    UomConversion[]  @relation("ConversionTo")

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@unique([tenantId, abbreviation])
    @@index([tenantId])
    @@index([tenantId, isActive])
    @@map("units_of_measure")
}

// Conversion factor between two units of measure.
// e.g. 1 CASE → 24 PIECES: fromUomId = CASE, toUomId = PIECE, factor = 24
// Conversion is applied at the service layer: quantityInTo = quantityInFrom × factor
model UomConversion {
    id               String  @id @default(uuid()) @db.Uuid
    tenantId         String  @db.Uuid
    fromUomId        String  @db.Uuid
    toUomId          String  @db.Uuid
    conversionFactor Decimal @db.Decimal(18, 6) // high precision for weight/volume conversions

    fromUom UnitOfMeasure @relation("ConversionFrom", fields: [fromUomId], references: [id])
    toUom   UnitOfMeasure @relation("ConversionTo", fields: [toUomId], references: [id])

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@unique([tenantId, fromUomId, toUomId])
    @@index([tenantId])
    @@map("uom_conversions")
}

// ─── Taxonomy ────────────────────────────────────────────────

// Hierarchical product taxonomy. Self-referencing for unlimited depth.
// e.g. Electronics → Mobile Phones → Android → Samsung
model Category {
    id          String  @id @default(uuid()) @db.Uuid
    tenantId    String  @db.Uuid
    name        String
    slug        String
    description String?
    parentId    String? @db.Uuid
    sortOrder   Int     @default(0)

    // Status
    isActive Boolean @default(true)

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Relations
    parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
    children Category[] @relation("CategoryHierarchy")
    products Product[]

    // Indexes
    @@unique([tenantId, slug])
    @@index([tenantId])
    @@index([tenantId, parentId])
    @@index([tenantId, isActive])
    @@index([deletedAt])
    @@map("categories")
}

// Product brand or manufacturer.
model Brand {
    id          String  @id @default(uuid()) @db.Uuid
    tenantId    String  @db.Uuid
    name        String
    slug        String
    description String?
    logoUrl     String?

    // Status
    isActive Boolean @default(true)

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Relations
    products Product[]

    // Indexes
    @@unique([tenantId, slug])
    @@unique([tenantId, name])
    @@index([tenantId])
    @@index([tenantId, isActive])
    @@index([deletedAt])
    @@map("brands")
}

// ─── Product ─────────────────────────────────────────────────

// Base product — shared attributes across all variants.
// A product is a grouping concept. Nothing is ever bought, sold,
// or stocked at the Product level — that always happens at the
// ProductVariant level.
//
// metadata: open JSON bag for cross-service feature flags.
// External services can read/write lightweight flags here
// without a schema migration. Examples:
//   { "isPOSVisible": true, "requiresSerialNumber": true,
//     "isSellable": true, "isConsumable": false }
model Product {
    id          String   @id @default(uuid()) @db.Uuid
    tenantId    String   @db.Uuid
    sku         String // base SKU — variants append a suffix
    name        String
    slug        String
    description String?
    tags        String[] // searchable tags e.g. ["electronics","mobile"]
    metadata    Json? // extensible feature flags (see comment above)

    // Statuss
    status ProductStatus @default(DRAFT)

    // Relations
    categoryId String           @db.Uuid
    category   Category         @relation(fields: [categoryId], references: [id])
    brandId    String?          @db.Uuid
    brand      Brand?           @relation(fields: [brandId], references: [id])
    variants   ProductVariant[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@unique([tenantId, sku])
    @@unique([tenantId, slug])
    @@index([tenantId])
    @@index([tenantId, categoryId])
    @@index([tenantId, brandId])
    @@index([tenantId, status])
    @@index([deletedAt])
    @@map("products")
}

// ─── Product Variant ─────────────────────────────────────────

// The atomic stockable and sellable unit.
// Every other microservice references variantId as the shared key.
//
// trackingType controls how inventory tracks individual units:
//   NONE   — standard quantity-based stock
//   SERIAL — each unit tracked individually via SerializedUnit
//   BATCH  — units grouped by InventoryLot (food, pharma)
//
// baseUomId — the UOM stock is internally tracked in (e.g. PCS).
// All StockMovement quantities are in this unit.
// Conversions to purchase/sale UOMs happen at the service layer.
model ProductVariant {
    id            String         @id @default(uuid()) @db.Uuid
    tenantId      String         @db.Uuid
    sku           String // globally unique per tenant — used on all documents
    name          String // e.g. "Samsung Galaxy S26 Ultra — 256GB Titanium Black"
    options       Json // { "storage": "256GB", "color": "Titanium Black" }
    trackingType  TrackingType   @default(NONE)
    weight        Float?
    length        Float?
    width         Float?
    height        Float?
    dimensionUnit DimensionUnit?
    weightUnit    WeightUnit?
    imageUrl      String? // single cover image URL
    metadata      Json?
    // metadata: extensible flags readable by external services
    // e.g. { "isSellable": true, "isConsumable": false, "warrantyMonths": 12 }

    // Status
    isActive Boolean @default(true)

    // Relations
    productId          String              @db.Uuid
    product            Product             @relation(fields: [productId], references: [id])
    baseUomId          String              @db.Uuid
    baseUom            UnitOfMeasure       @relation(fields: [baseUomId], references: [id])
    inventoryItems     InventoryItem[]
    inventoryLots      InventoryLot[]
    stockMovements     StockMovement[]
    serializedUnits    SerializedUnit[]
    transferItems      StockTransferItem[]
    stockCountItems    StockCountItem[]
    returnRequestItems ReturnRequestItem[]
    stockAlerts        StockAlert[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@unique([tenantId, sku])
    @@index([tenantId])
    @@index([tenantId, productId])
    @@index([tenantId, isActive])
    @@index([deletedAt])
    @@map("product_variants")
}

// ─── Back-relations added to satisfy Prisma relation completeness ─

// ProductVariant back-relations are declared inline above.
// StockTransferItem, StockCountItem, ReturnRequestItem back-relations
// are declared on InventoryLot and BinLocation in inventory.prisma.
