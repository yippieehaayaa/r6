// ============================================================
//  WAREHOUSE
//  Physical and logical locations that hold stock.
//
//  Hierarchy: Warehouse → WarehouseZone → BinLocation
//    Warehouse     — top-level facility (e.g. "Manila Central", WH-MNL)
//    WarehouseZone — named zone within a warehouse
//                    (e.g. "Zone A — Refrigerated", "Zone B — Dry Goods")
//    BinLocation   — specific shelf/bin within a zone (e.g. "A-01-03")
//                    InventoryLot.binLocationId enables directed putaway
//                    and picking workflows.
//
//  Multi-tenancy:
//    tenantId? — null is reserved for platform ADMIN visibility.
//    All tenant-owned records carry a non-null tenantId.
//    PostgreSQL RLS enforces row-level isolation per tenant.
// ============================================================

model Warehouse {
    id          String  @id @default(uuid()) @db.Uuid
    tenantId    String? @db.Uuid
    name        String
    code        String  // Short identifier e.g. "WH-MNL", "WH-CDO"
    description String?
    isActive    Boolean @default(true)

    // Flattened address — no join needed for a single-owner entity
    addressLine1    String
    addressLine2    String?
    addressBarangay String?
    addressCity     String
    addressProvince String?
    addressState    String
    addressCountry  String  @default("PH")
    addressPostal   String
    landmark        String?

    // Contact info
    contactName  String?
    contactPhone String?
    contactEmail String?

    // Relations
    zones             WarehouseZone[]
    inventoryItems    InventoryItem[]
    inventoryLots     InventoryLot[]
    stockMovements    StockMovement[]
    transfersFrom     StockTransfer[]   @relation("TransferFrom")
    transfersTo       StockTransfer[]   @relation("TransferTo")
    stockCounts       StockCount[]
    stockReservations StockReservation[]
    alerts            StockAlert[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    @@unique([tenantId, code])
    @@unique([tenantId, name])
    @@index([tenantId])
    @@index([tenantId, isActive])
    @@index([deletedAt])
    @@map("warehouses")
}

// Named zone within a warehouse.
// Enables directed putaway strategies (refrigerated, ambient, hazardous, etc.)
// and zone-based picking waves.
model WarehouseZone {
    id          String  @id @default(uuid()) @db.Uuid
    tenantId    String? @db.Uuid
    warehouseId String  @db.Uuid
    name        String
    code        String
    description String?
    isActive    Boolean @default(true)

    // Relations
    warehouse    Warehouse     @relation(fields: [warehouseId], references: [id])
    binLocations BinLocation[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    @@unique([tenantId, warehouseId, code])
    @@index([tenantId])
    @@index([tenantId, warehouseId])
    @@index([tenantId, warehouseId, isActive])
    @@index([deletedAt])
    @@map("warehouse_zones")
}

// Specific shelf or bin location within a zone.
// Format convention: "{Zone}-{Aisle}-{Shelf}-{Tier}" e.g. "A-01-03-B"
// InventoryLot.binLocationId pins a lot to a bin for directed picking.
model BinLocation {
    id          String  @id @default(uuid()) @db.Uuid
    tenantId    String? @db.Uuid
    zoneId      String  @db.Uuid
    code        String  // e.g. "A-01-03-B"
    description String?
    isActive    Boolean @default(true)

    // Relations
    zone            WarehouseZone    @relation(fields: [zoneId], references: [id])
    inventoryLots   InventoryLot[]
    stockCountItems StockCountItem[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    @@unique([tenantId, zoneId, code])
    @@index([tenantId])
    @@index([tenantId, zoneId])
    @@index([deletedAt])
    @@map("bin_locations")
}
