enum GenerationStatus {
  PENDING
  READY
  FAILED
}

enum CardImageFormat {
  PNG
  WEBP
}

model DynamicQr {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  publicId     String           @unique @default(uuid())
  companyName  String
  qrTargetUrl  String
  profileLabel String?
  issuedDate   DateTime
  logoPngBytes Bytes?
  outputDefaults Json
  metadata     Json?
  status       GenerationStatus @default(READY)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  businessCards BusinessCard[]

  @@index([companyName])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("dynamic_qr")
}

model BusinessCard {
  id                 String           @id @default(auto()) @map("_id") @db.ObjectId
  publicId           String           @unique @default(uuid())
  companyName        String
  qrCodePublicId     String
  issuedDate         DateTime
  editionLabel       String
  imageFormat        CardImageFormat  @default(PNG)
  printSpec          Json
  theme              Json
  companyLogoPngBytes Bytes?
  metadata           Json?
  status             GenerationStatus @default(READY)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  qrCode DynamicQr @relation(fields: [qrCodePublicId], references: [publicId], onDelete: NoAction, onUpdate: NoAction)

  @@index([qrCodePublicId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("business_cards")
}
