    "lint": "biome lint --write .",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "@r6/schemas": "*",
    "dotenv": "^17.3.1",
    "express": "5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.4",
    "prisma": "6.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@r6/typescript-config": "*",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/qrcode": "^1.5.5",
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "prisma": {
    "schema": "prisma/schema"
  }
