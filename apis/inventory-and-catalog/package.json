{
	"name": "@r6/inventory-and-catalog",
	"version": "1.0.0",
	"scripts": {
		"build": "tsc",
		"check": "biome check --write .",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:push": "prisma db push",
		"db:seed": "prisma db seed",
		"db:seed:fresh": "tsx prisma/seed/index.ts --fresh",
		"db:studio": "prisma studio",
		"dev": "tsx watch ./src/index.ts",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"start": "node ./dist/index.js"
	},
	"dependencies": {
		"@prisma/client": "6.19.0",
		"dotenv": "^17.4.0",
		"express": "5.2.1",
		"helmet": "^8.1.0",
		"morgan": "^1.10.1",
		"prisma": "6.19.0",
		"tsx": "^4.21.0",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@faker-js/faker": "^10.4.0",
		"@r6/schemas": "*",
		"@r6/typescript-config": "*",
		"@types/express": "^5.0.6",
		"@types/morgan": "^1.9.10",
		"typescript": "6.0.2"
	},
	"author": "Joshua Dave E. Oropilla",
	"license": "MIT",
	"prisma": {
		"schema": "prisma/schema",
		"seed": "npx tsx prisma/seed/index.ts"
	}
}
