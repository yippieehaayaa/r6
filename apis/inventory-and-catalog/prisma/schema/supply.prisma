// Vendor / supplier of goods
model Supplier {
    id             String        @id @default(auto()) @map("_id") @db.ObjectId
    tenantSlug     String
    name           String
    code           String
    contactName    String?
    contactEmail   String?
    contactPhone   String?
    address        AddressEmbed?
    isActive       Boolean       @default(true)

    // Relations
    purchaseOrders PurchaseOrder[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@unique([tenantSlug, name])
    @@unique([tenantSlug, code])
    @@index([tenantSlug])
    @@index([tenantSlug, isActive])
    @@index([deletedAt])
    @@map("suppliers")
}

// Replenishment order raised against a supplier
model PurchaseOrder {
    id          String              @id @default(auto()) @map("_id") @db.ObjectId
    tenantSlug  String
    orderNumber String
    status      PurchaseOrderStatus @default(DRAFT)
    expectedAt  DateTime?
    notes       String?

    // Relations
    supplierId String   @db.ObjectId
    supplier   Supplier @relation(fields: [supplierId], references: [id])

    warehouseId String    @db.ObjectId
    warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

    items PurchaseOrderItem[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@unique([tenantSlug, orderNumber])
    @@index([tenantSlug])
    @@index([tenantSlug, supplierId])
    @@index([tenantSlug, supplierId, status])
    @@index([tenantSlug, warehouseId])
    @@index([tenantSlug, status])
    @@index([deletedAt])
    @@map("purchase_orders")
}

// Individual line item on a purchase order — O(1) via composite unique
model PurchaseOrderItem {
    id               String @id @default(auto()) @map("_id") @db.ObjectId
    tenantSlug       String
    quantityOrdered  Int
    quantityReceived Int    @default(0)
    unitCost         Int

    // Relations
    purchaseOrderId String        @db.ObjectId
    purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

    variantId String         @db.ObjectId
    variant   ProductVariant @relation(fields: [variantId], references: [id])

    // Timestamps
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Composite unique → prevents duplicate line items per order, scoped to tenant
    @@unique([tenantSlug, purchaseOrderId, variantId])
    @@index([tenantSlug])
    @@index([variantId])
    @@map("purchase_order_items")
}
