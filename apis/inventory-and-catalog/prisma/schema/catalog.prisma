// Hierarchical product taxonomy (self-referencing)
model Category {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    name        String
    slug        String   @unique
    description String?
    parentId    String?  @db.ObjectId
    isActive    Boolean  @default(true)
    sortOrder   Int      @default(0)

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Relations
    products  Product[]

    // Indexes — O(1) equality filters per access pattern
    @@index([parentId])
    @@index([isActive])
    @@index([deletedAt])
    @@map("categories")
}

// Product brand / manufacturer
model Brand {
    id          String  @id @default(auto()) @map("_id") @db.ObjectId
    name        String  @unique
    slug        String  @unique
    description String?
    logoUrl     String?
    isActive    Boolean @default(true)

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Relations
    products Product[]

    // Indexes
    @@index([isActive])
    @@index([deletedAt])
    @@map("brands")
}

// Base product (contains shared attributes across all variants)
model Product {
    id          String        @id @default(auto()) @map("_id") @db.ObjectId
    sku         String        @unique
    name        String
    slug        String        @unique
    description String?
    tags        String[]
    status      ProductStatus @default(DRAFT)
    isActive    Boolean       @default(true)
    metadata    Json?

    // Relations
    categoryId String   @db.ObjectId
    category   Category @relation(fields: [categoryId], references: [id])

    brandId String? @db.ObjectId
    brand   Brand?  @relation(fields: [brandId], references: [id])

    variants ProductVariant[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@index([categoryId])
    @@index([brandId])
    @@index([status])
    @@index([isActive])
    @@index([deletedAt])
    @@map("products")
}

// Purchasable / stockable unit of a product (e.g. size + colour combination)
model ProductVariant {
    id             String       @id @default(auto()) @map("_id") @db.ObjectId
    sku            String       @unique
    name           String
    options        Json         // { "color": "red", "size": "M" }
    price          Float
    compareAtPrice Float?
    weight         Float?
    images         ImageEmbed[]
    isActive       Boolean      @default(true)

    // Relations
    productId String  @db.ObjectId
    product   Product @relation(fields: [productId], references: [id])

    inventoryItems    InventoryItem[]
    stockMovements    StockMovement[]
    purchaseOrderItems PurchaseOrderItem[]

    // Timestamps
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    // Indexes
    @@index([productId])
    @@index([isActive])
    @@index([deletedAt])
    @@map("product_variants")
}
