meta {
  name: List Orders
  type: http
  seq: 1
}

get {
  url: {{baseURL}}/procurement/orders?page=1&limit=20
  body: none
  auth: none
}

params:query {
  page: 1
  limit: 20
  ~supplierId: {{supplierId}}
  ~warehouseId: {{warehouseId}}
  ~status: draft
  ~from: 2025-01-01T00:00:00.000Z
  ~to: 2025-12-31T23:59:59.999Z
}
