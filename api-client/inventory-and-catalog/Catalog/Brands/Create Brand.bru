meta {
  name: Create Brand
  type: http
  seq: 2
}

post {
  url: {{baseURL}}/catalog/brands
  body: json
  auth: none
}

body:json {
  {
    "name": "Nike",
    "slug": "nike",
    "description": "Just Do It",
    "logoUrl": "https://example.com/logos/nike.png",
    "isActive": true
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("brandId", res.body.id);
  }
}
