meta {
  name: Create Category
  type: http
  seq: 2
}

post {
  url: {{baseURL}}/catalog/categories
  body: json
  auth: none
}

body:json {
  {
    "name": "Footwear",
    "slug": "footwear",
    "description": "All footwear products",
    "isActive": true,
    "sortOrder": 1
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("categoryId", res.body.id);
  }
}
