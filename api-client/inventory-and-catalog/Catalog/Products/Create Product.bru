meta {
  name: Create Product
  type: http
  seq: 2
}

post {
  url: {{baseURL}}/catalog/products
  body: json
  auth: none
}

body:json {
  {
    "sku": "FW-RUN-001",
    "name": "Classic Runner",
    "slug": "classic-runner",
    "description": "A timeless running shoe",
    "tags": ["running", "classic"],
    "categoryId": "{{categoryId}}",
    "brandId": "{{brandId}}"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("productId", res.body.id);
  }
}
