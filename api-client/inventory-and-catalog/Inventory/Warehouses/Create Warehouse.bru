meta {
  name: Create Warehouse
  type: http
  seq: 2
}

post {
  url: {{baseURL}}/inventory/warehouses
  body: json
  auth: none
}

body:json {
  {
    "name": "Main Warehouse",
    "code": "WH-MAIN",
    "address": {
      "street": "123 Storage Lane",
      "city": "Metro City",
      "state": "CA",
      "country": "US",
      "postal": "90210"
    },
    "isActive": true
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("warehouseId", res.body.id);
  }
}
