meta {
  name: List Movements
  type: http
  seq: 1
}

get {
  url: {{baseURL}}/inventory/movements/{{variantId}}?page=1&limit=20
  body: none
  auth: none
}

params:query {
  page: 1
  limit: 20
  ~type: SALE
  ~warehouseId: {{warehouseId}}
  ~from: 2025-01-01T00:00:00.000Z
  ~to: 2025-12-31T23:59:59.999Z
}
