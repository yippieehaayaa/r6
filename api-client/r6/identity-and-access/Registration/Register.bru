meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{iamURL}}/registration
  body: json
  auth: none
}

body:json {
  {
    "username": "johndoe",
    "email": "john@example.com",
    "password": "Password@1234!",
    "firstName": "John",
    "lastName": "Doe",
    "country": "US"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("registerEmail", JSON.parse(req.body).email);
  }
}
