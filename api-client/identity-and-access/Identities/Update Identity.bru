meta {
  name: Update Identity
  type: http
  seq: 4
}

patch {
  url: {{baseURL}}/tenants/{{tenantSlug}}/identities/{{identityId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "username": "johndoe_updated",
    "email": "johndoe_updated@example.com",
    "status": "ACTIVE"
  }
}
