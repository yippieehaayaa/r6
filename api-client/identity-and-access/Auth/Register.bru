meta {
  name: Register
  type: http
  seq: 5
}

post {
  url: {{baseURL}}/auth/register
  body: json
  auth: none
}

body:json {
  {
    "username": "johndoe",
    "email": "john@example.com",
    "password": "Password@1234!"
  }
}

script:post-response {
  if (res.status === 201) {
    // Store the email for use in the Verify Email request.
    bru.setEnvVar("registerEmail", JSON.parse(req.body).email);
  }
}
