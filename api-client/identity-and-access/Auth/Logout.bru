meta {
  name: Logout
  type: http
  seq: 4
}

post {
  url: {{baseURL}}/auth/logout
  body: json
  auth: none
}

body:json {
  {
    "token": "{{refreshToken}}"
  }
}

script:post-response {
  if (res.status === 204) {
    bru.setEnvVar("accessToken", "");
    bru.setEnvVar("refreshToken", "");
  }
}
