meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseURL}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "tenantSlug": "demo-corp",
    "username": "testuser",
    "password": "User@1234!"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("accessToken", res.body.accessToken);
    bru.setEnvVar("refreshToken", res.body.refreshToken);
  }
}
