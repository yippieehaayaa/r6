post {
  url: {{baseURL}}/tenants/{{tenantSlug}}/provision
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "username": "tenant-admin",
    "plainPassword": "Password1!",
