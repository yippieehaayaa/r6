meta {
  name: Reconcile Stock Count
  type: http
  seq: 5
}

post {
  url: {{baseURL}}/tenants/{{tenantSlug}}/stock-counts/{{stockCountId}}/reconcile
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "supervisedBy": "{{supervisorId}}",
    "varianceReasons": {
      "{{stockCountItemId}}": "Damaged items removed"
    }
  }
}
