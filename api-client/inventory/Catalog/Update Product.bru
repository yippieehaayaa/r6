meta {
  name: Update Product
  type: http
  seq: 3
}

patch {
  url: {{baseURL}}/tenants/{{tenantSlug}}/catalog/products/{{productId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "name": "Updated Product Name",
    "description": "Updated description",
    "tags": ["tag1", "tag2"]
  }
}
