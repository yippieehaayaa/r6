{
	"name": "@r6/schemas",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"build": "NODE_OPTIONS='--max-old-space-size=4096' tsup src",
		"check": "biome check --write .",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"watch": "tsup src --watch"
	},
	"dependencies": {
		"lodash": "^4.17.23",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@r6/typescript-config": "*",
		"@types/lodash": "^4.17.24",
		"@types/node": "^25.5.0",
		"tsup": "8.5.1",
		"typescript": "5.9.3"
	},
	"author": "Joshua Dave Oropilla",
	"description": "",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./*": {
			"types": "./dist/*/index.d.ts",
			"import": "./dist/*/index.mjs",
			"require": "./dist/*/index.js",
			"default": "./dist/*/index.js"
		}
	},
	"license": "MIT",
	"main": "./dist/index.js",
	"module": "/dist/index.mjs",
	"sideEffects": false,
	"types": "./dist/index.d.ts"
}
