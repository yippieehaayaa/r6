{
	"name": "@r6/auth0",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"build": "tsup src",
		"check": "biome check --write .",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"watch": "tsup src --watch"
	},
	"dependencies": {
		"express-oauth2-jwt-bearer": "^1.7.4",
		"express-openid-connect": "^2.20.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@r6/typescript-config": "*",
		"@types/express": "^5.0.6",
		"tsup": "8.5.1",
		"typescript": "6.0.2"
	},
	"author": "Joshua Dave E. Oropilla <joshdave0915@gmail.com>",
	"description": "Shared Auth0 (Okta) middleware helpers for Express services",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"license": "MIT",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"sideEffects": false,
	"types": "./dist/index.d.ts"
}
