{
	"name": "@r6/totp",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"build": "tsup src",
		"check": "biome check --write .",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"watch": "tsup src --watch"
	},
	"dependencies": {
		"otplib": "^12.0.1",
		"qrcode": "^1.5.4"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@r6/typescript-config": "*",
		"@types/node": "^25.5.2",
		"@types/qrcode": "^1.5.5",
		"tsup": "8.5.1",
		"typescript": "6.0.2"
	},
	"author": "Joshua Dave E. Oropilla <joshdave0915@gmail.com>",
	"description": "TOTP (Time-based One-Time Password) utilities — secret generation, AES-256-GCM encryption, provisioning URI and QR code generation, code verification",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"license": "MIT",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts"
}
