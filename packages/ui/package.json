		"embla-carousel-react": "^8.6.0",
		"input-otp": "^1.4.2",
		"lucide-react": "^0.545.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react-day-picker": "^9.14.0",
		"react-resizable-panels": "^4.7.3",
		"recharts": "^2.15.4",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"vaul": "^1.1.2"
	},
	"peerDependencies": {
		"react": "^19.2.0",
		"react-dom": "^19.2.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@r6/typescript-config": "*",
